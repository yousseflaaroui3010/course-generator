# ============================================================
# Lumina — Environment Variables
# Copy this file to .env and fill in values for local dev.
# NEVER commit .env to git.
# ============================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql://lumina:lumina_dev@localhost:5432/lumina_dev
POSTGRES_USER=lumina
POSTGRES_PASSWORD=lumina_dev
POSTGRES_DB=lumina_dev

# --- KeyCloak ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=lumina
KEYCLOAK_CLIENT_ID=lumina-web
KEYCLOAK_CLIENT_SECRET=
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Supabase Storage ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Gemini AI ---
GEMINI_API_KEY=
CUSTOM_GEMINI_API_KEY=

# --- App ---
NODE_ENV=development
PORT=3000
